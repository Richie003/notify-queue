# Copy to .env at the repo root and adjust as needed for local (non-docker) runs.
# src/config/settings.py loads this automatically via python-dotenv.

DATABASE_URL=postgresql://notify:notify@localhost:5432/notify_queue

DEBUG=true
SECRET_KEY=dev-only-secret-change-me
ALLOWED_HOSTS=*

# Worker
POLL_INTERVAL_SECONDS=1.0
CLAIM_BATCH_SIZE=10
VISIBILITY_TIMEOUT_SECONDS=30

# Mock delivery
FAILURE_RATE=0.3
SEND_LATENCY_MIN_MS=20
SEND_LATENCY_MAX_MS=150

# Retry / backoff
DEFAULT_MAX_ATTEMPTS=5
BACKOFF_BASE_SECONDS=2.0
BACKOFF_CAP_SECONDS=300
BACKOFF_JITTER=0.2

# Rate limiting
RATE_LIMIT_PER_RECIPIENT_PER_HOUR=5
RATE_LIMIT_RECHECK_SECONDS=15

# Webhooks (NOTE the trailing slash -- see repository.py / settings.py comment)
DEFAULT_WEBHOOK_URL=http://localhost:8000/webhooks/mock/
WEBHOOK_TIMEOUT_SECONDS=5.0
